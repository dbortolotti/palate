OPENAI_API_KEY=your-openai-api-key
OMDB_API_KEY=
PALATE_DB_PATH=./data/palate.sqlite
PALATE_MODEL=gpt-5.4-mini
PALATE_BACKUP_ENABLED=1
PALATE_BACKUP_DIR=./backups
PALATE_BACKUP_RETENTION_DAYS=31
PALATE_BACKUP_INTERVAL_SECONDS=86400
PALATE_BACKUP_GOOGLE_DRIVE_ENABLED=0
PALATE_GOOGLE_DRIVE_FOLDER_NAME=backup/palate
PALATE_GOOGLE_CREDENTIALS_PATH=./secrets/google-oauth-client.json
PALATE_GOOGLE_TOKEN_PATH=./secrets/google-token.json
PALATE_AUTH_ENABLED=0
PALATE_PUBLIC_BASE_URL=https://example.com/palate
PALATE_AUTH_SCOPES=palate.access
PALATE_AUTH_PASSWORD_FILE=./secrets/palate-auth-password
PALATE_AUTH_STATE_PATH=./secrets/palate-oauth.json
